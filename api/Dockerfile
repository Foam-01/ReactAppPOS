# 1. เลือก Base Image: เริ่มต้นจากระบบปฏิบัติการ Linux จิ๋ว (Alpine) ที่ลง Node.js v18 ไว้ให้แล้ว
FROM node:18-alpine

# 2. ตั้งฐานทัพ: สร้างโฟลเดอร์ชื่อ /app ในกล่อง แล้วให้เข้าไปสิงอยู่ในนั้นเลย
WORKDIR /app

# 3. เอาบัญชีรายชื่อแพ็กเกจเข้าไปก่อน: ก๊อปปี้ไฟล์ package.json (และ package-lock.json ถ้ามี) เข้าไปใน /app
COPY package*.json ./

# 4. สั่งโหลดของ: รันคำสั่งนี้เพื่อดาวน์โหลด node_modules ใหม่เอี่ยมที่เข้ากับระบบ Linux ในกล่อง
RUN npm install

# 5. ขนของเข้ากล่อง: ก๊อปปี้โค้ด API ของคุณ (พวก controller, model, server.js) เข้าไปให้หมด (มันจะไม่ก๊อปของที่อยู่ใน .dockerignore)
COPY . .

# 6. เจาะช่องให้คนนอกคุยด้วย: บอกว่ากล่องนี้จะเปิดรับการเชื่อมต่อที่พอร์ต 3000 นะ
EXPOSE 3000

# 7. สั่งสตาร์ทเครื่อง: พอกล่องถูกเปิดขึ้นมาปุ๊บ ให้มันรันคำสั่ง npm start อัตโนมัติ
CMD ["npm", "start"]